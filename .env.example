# ╔══════════════════════════════════════════════════════════════════╗
# ║  DocTalk VoiceToText — Variables de entorno                     ║
# ║  Copia este archivo como .env y ajusta los valores              ║
# ║  cp .env.example .env                                          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────────
# SERVIDOR NODE.JS
# ──────────────────────────────────────────────────────────────────

# Puerto en el que escucha el servidor Node.js (server.js).
# Este puerto es al que apunta el rewrite de IIS en web.config.
# Opciones: cualquier puerto libre (1024–65535)
# Default: 3000
PORT=3005

# Entorno de ejecución de Node.js.
# - "production"  → build optimizado, sin hot-reload
# - "development" → hot-reload con Turbopack (npm run dev)
# Default: development
NODE_ENV=production

# ──────────────────────────────────────────────────────────────────
# FRONTEND (variables NEXT_PUBLIC_* se inyectan en el bundle del navegador)
# ──────────────────────────────────────────────────────────────────

# Ruta del WebSocket para la transcripción en tiempo real.
# El navegador construye la URL completa a partir de este valor.
# - "/ws"                   → relativa al dominio actual (recomendado con IIS)
# - "ws://localhost:3005/ws" → absoluta (útil en desarrollo sin proxy)
# - "wss://midominio.com/ws" → absoluta con SSL
# Default: /ws
NEXT_PUBLIC_WS_URL=/ws

# Modelo Whisper seleccionado por defecto en la UI al cargar la página.
# El usuario puede cambiarlo desde el selector en la interfaz.
# Opciones:
#   tiny      → 75 MB  | Calidad baja       | Muy rápido
#   base      → 140 MB | Calidad media       | Rápido (recomendado para CPU)
#   small     → 460 MB | Calidad buena       | Moderado
#   medium    → 1.5 GB | Calidad muy buena   | Lento en CPU
#   large-v3  → 3 GB   | Calidad excelente   | Requiere GPU o mucha RAM
# Default: base
NEXT_PUBLIC_DEFAULT_MODEL=base

# ──────────────────────────────────────────────────────────────────
# BACKEND — FASTER-WHISPER SERVER (Docker)
# ──────────────────────────────────────────────────────────────────

# URL del REST API de Faster-Whisper Server.
# server.js y /api/transcribe envían los audios aquí via POST.
#
# Escenarios comunes:
#   http://localhost:8000          → Whisper en Docker en la misma máquina
#   http://whisper:8000            → Dentro de Docker Compose (nombre del servicio)
#   http://192.168.1.50:8000       → Whisper en otra máquina de la red local
#   https://whisper.midominio.com  → Whisper tras un proxy con SSL
#
# El endpoint que se usa internamente es:
#   ${WHISPER_API_URL}/v1/audio/transcriptions
#
# Default: http://localhost:8000
WHISPER_API_URL=http://localhost:8000

# ──────────────────────────────────────────────────────────────────
# DIARIZACIÓN (identificación de hablantes: doctor / paciente)
# ──────────────────────────────────────────────────────────────────

# URL del microservicio de diarización (WhisperX + pyannote).
# Si está vacío o no se define, la diarización se desactiva y
# la transcripción funciona normalmente sin identificar hablantes.
#
# Escenarios comunes:
#   http://localhost:8001          → Diarización en Docker en la misma máquina
#   http://diarize:8001            → Dentro de Docker Compose
#   (vacío)                        → Deshabilitado
#
# Default: (vacío = deshabilitado)
DIARIZE_API_URL=http://localhost:8001

# Token de HuggingFace (requerido para diarización con pyannote).
# Pasos para obtenerlo:
#   1. Crear cuenta en https://huggingface.co
#   2. Aceptar la licencia de pyannote:
#      - https://huggingface.co/pyannote/speaker-diarization-3.1
#      - https://huggingface.co/pyannote/segmentation-3.0
#   3. Generar token en https://huggingface.co/settings/tokens
#
# Solo es necesario si usas el servicio de diarización.
# Default: (vacío)
HF_TOKEN=
