<?xml version="1.0" encoding="UTF-8"?>
<!--
  IIS Reverse Proxy → Node.js (VoiceToText)
  Requiere:
    • URL Rewrite Module  — https://www.iis.net/downloads/microsoft/url-rewrite
    • Application Request Routing (ARR) — https://www.iis.net/downloads/microsoft/application-request-routing
    • WebSocket Protocol  — Activar en "Características de Windows"
  Pasos:
    1. Copiar este web.config a la carpeta del sitio IIS.
    2. En IIS Manager → ARR → Server Proxy Settings → Habilitar proxy.
    3. Ajustar el puerto si no es 3005 (debe coincidir con .env PORT).
-->
<configuration>
  <system.webServer>

    <!-- Habilitar WebSocket en IIS -->
    <webSocket enabled="true" />

    <rewrite>
      <rules>

        <!-- 1. WebSocket upgrade  (ws:// / wss://) -->
        <rule name="WS-Proxy" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTP_UPGRADE}" pattern="websocket" ignoreCase="true" />
          </conditions>
          <action type="Rewrite" url="http://localhost:3005/{R:1}" />
        </rule>

        <!-- 2. HTTP reverse proxy (todo lo demás) -->
        <rule name="HTTP-Proxy" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://localhost:3005/{R:1}" />
        </rule>

      </rules>
    </rewrite>

  </system.webServer>
</configuration>
